{
  "expo": {
    "name": "Hardwoods",
    "slug": "hardwoods",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "hardwoods",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hardwoods.scoreboard",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight",
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#180C01",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hardwoods.scoreboard"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#180C01",
          "resizeMode": "contain",
          "imageWidth": 220
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e118b356-ed84-430e-9fa7-d0efb5f956a0"
      }
    }
  }
}
